          "BTTTriggerTypeDescription": "Keyboard Shortcut",
          "BTTTriggerClass": "BTTTriggerTypeKeyboardShortcut",
          "BTTUUID": "155C72AE-BAED-44D6-A5CE-DC9E303A39DD",
          "BTTTriggerOnDown": 1,
          "BTTEnabled": 1,
          "BTTEnabled2": 1,
          "BTTShortcutKeyCode": 123,
          "BTTShortcutModifierKeys": 8388608,
          "BTTOrder": 3,
