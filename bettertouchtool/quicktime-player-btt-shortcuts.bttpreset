                "BTTAppleScriptRunInBackground": false,
                "BTTScriptType": 3,
                "BTTAppleScriptString": "tell application \"QuickTime Player\"\n    if (exists document 1) then\n        set docRef to document 1\n        set newTime to (current time of docRef) - 7\n        if newTime < 0 then set newTime to 0\n        set current time of docRef to newTime\n    end if\nend tell",
