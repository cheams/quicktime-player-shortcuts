          "BTTTriggerTypeDescription": "Keyboard Shortcut",
          "BTTTriggerClass": "BTTTriggerTypeKeyboardShortcut",
          "BTTUUID": "6CBD7F40-DE8F-4AD6-B70A-D7B45F6487B3",
          "BTTTriggerOnDown": 1,
