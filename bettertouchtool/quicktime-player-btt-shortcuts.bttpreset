          "BTTActionsToExecute": [
            {
              "BTTPredefinedActionType": 172,
              "BTTPredefinedActionName": "Run Apple Script (blocking)",
              "BTTAdditionalActionData": {
                "BTTAppleScriptRunInBackground": false,
                "BTTScriptType": 0,
                "BTTAppleScriptString": "tell application \"QuickTime Player\"\n    if not (exists document 1) then return\n    set theDoc to document 1\n    set newTime to (current time of theDoc) - 7\n    if newTime < 0 then set newTime to 0\n    set current time of theDoc to newTime\nend tell",
                "BTTAppleScriptUsePath": false,
                "BTTScriptLocation": 0
              }
            }
          ]
        },
        {
          "BTTActionCategory": 0,
