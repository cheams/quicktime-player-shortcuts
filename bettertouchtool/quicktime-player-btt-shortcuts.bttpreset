          "BTTAutoAdaptToKeyboardLayout": 0,
          "BTTActionsToExecute": [
            {
              "BTTPredefinedActionType": 172,
              "BTTPredefinedActionName": "Run Apple Script (blocking)",
              "BTTAdditionalActionData": {
                "BTTAppleScriptRunInBackground": false,
                "BTTScriptType": 0,
                "BTTAppleScriptString": "tell application \"QuickTime Player\"\n    if not (exists document 1) then return\n    set theDoc to front document\n    set currentRate to get «property rate» of theDoc\n    if currentRate < 1.0 then set currentRate to 1.0\n    set newRate to currentRate + 0.5\n    «event MVWRplay» theDoc\n    delay 0.05\n    set «property rate» of theDoc to newRate\nend tell",
