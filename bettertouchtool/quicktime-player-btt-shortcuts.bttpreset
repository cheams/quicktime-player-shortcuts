          "BTTActionsToExecute": [
            {
              "BTTPredefinedActionType": 172,
              "BTTPredefinedActionName": "Run Apple Script (blocking)",
              "BTTAdditionalActionData": {
                "BTTAppleScriptRunInBackground": false,
                "BTTScriptType": 0,
                "BTTAppleScriptString": "tell application \"QuickTime Player\"\n    if not (exists document 1) then return\n    set theDoc to document 1\n    set newTime to (current time of theDoc) + 7\n    set docDuration to duration of theDoc\n    if newTime > docDuration then set newTime to docDuration\n    set current time of theDoc to newTime\nend tell",
                "BTTAppleScriptUsePath": false,
                "BTTScriptLocation": 0
              }
            }
          ]
        }
